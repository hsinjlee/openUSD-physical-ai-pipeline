#usda 1.0
(
    defaultPrim = "Robot"
    metersPerUnit = 1
    subLayers = [
        @../../03_robot_asset_library/output/robot.usda@
    ]
    upAxis = "Y"
)

over "Robot" (
    prepend apiSchemas = ["PhysicsArticulationRootAPI"]
)
{
    over "Base" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI"]
    )
    {
        float physics:mass = 10

        over "Geom" (
            prepend apiSchemas = ["PhysicsCollisionAPI"]
        )
        {
        }
    }

    over "Arm" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI"]
    )
    {
        float physics:mass = 2

        over "Geom" (
            prepend apiSchemas = ["PhysicsCollisionAPI"]
        )
        {
        }
    }

    def PhysicsFixedJoint "FixedBaseJoint"
    {
        rel physics:body1 = </Robot/Base>
    }

    def PhysicsRevoluteJoint "ArmJoint"
    {
        uniform token physics:axis = "Z"
        rel physics:body0 = </Robot/Base>
        rel physics:body1 = </Robot/Arm>
        point3f physics:localPos0 = (0, 0.75, 0)
        point3f physics:localPos1 = (0, -0.25, 0)
        float physics:lowerLimit = -90
        float physics:upperLimit = 90
    }

    def PhysicsScene "PhysicsScene"
    {
        vector3f physics:gravityDirection = (0, -1, 0)
        float physics:gravityMagnitude = 9.81
    }
}

